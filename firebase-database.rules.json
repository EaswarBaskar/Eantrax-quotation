{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "app_data": {
          ".validate": "newData.hasChildren(['documents', 'clients', 'catalog', 'settings'])"
        }
      }
    }
  }
}
